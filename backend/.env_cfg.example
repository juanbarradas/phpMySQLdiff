# MySQL Schema Diff Tool — Environment Configuration
# =====================================================
# Copy this file as .env_cfg and adjust values as needed.

# Application settings
APP_ENV=development
APP_DEBUG=true
APP_BASE_PATH=/mysqlcompare/compare_php/

# CORS — use '*' for dev or a specific origin for production, e.g.: http://localhost/compare
CORS_ORIGIN=*

# History storage — SQLite file path (relative to backend root)
HISTORY_DB_PATH=./history/history.sqlite

# Maximum history entries to keep before auto-pruning
MAX_HISTORY_ENTRIES=100

# MySQL connection timeout (seconds)
DB_CONNECT_TIMEOUT=10

# MySQL query execution timeout (seconds)
DB_QUERY_TIMEOUT=60
